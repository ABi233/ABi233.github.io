<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }} - {{ site.title }}</title>
  <link rel="stylesheet" href="{{ '/assets/css/toc.css' | relative_url }}">
  <!-- Rouge One Dark: colours for server-side highlighted code (GitHub Pages) -->
  <link rel="stylesheet" href="{{ '/assets/css/rouge-one-dark.css' | relative_url }}">
  <!-- Prism.js One Dark: colours for client-side highlighted code (local build) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prism-themes@1.9.0/themes/prism-one-dark.min.css">
  <!-- Prism line-numbers plugin CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.css">
  <!-- Prism toolbar plugin CSS (for the copy button bar) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/toolbar/prism-toolbar.min.css">
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <h1 class="site-title"><a href="{{ '/' | relative_url }}">{{ site.title }}</a></h1>
    </div>
  </header>

  <div class="wrap layout">
    <main class="content" role="main">
      <article class="post">
        <header class="post-header">
          <h1 class="post-title">{{ page.title }}</h1>
        </header>

        <div class="post-body">
          {{ content }}
        </div>
      </article>
    </main>

    <aside class="toc-sidebar" id="toc" aria-label="文章大纲">
      <!-- 目录由 assets/js/toc.js 动态生成 -->
    </aside>
  </div>

  <footer class="site-footer">
    <div class="wrap">&copy; {{ site.time | date: "%Y" }} {{ site.title }}</div>
  </footer>

  <script src="{{ '/assets/js/toc.js' | relative_url }}"></script>
  <!-- Tell Prism NOT to auto-highlight; code-enhance.js will call
       Prism.highlightAll() after preparing the DOM (copying language-*
       classes from <code> to <pre>, adding line-numbers, etc.). -->
  <script>window.Prism = window.Prism || {}; Prism.manual = true;</script>
  <!-- Prism core + autoloader (loads language grammars on demand) -->
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-core.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
  <!-- Prism line-numbers plugin -->
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/line-numbers/prism-line-numbers.min.js"></script>
  <!-- Prism toolbar + copy-to-clipboard plugin -->
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/toolbar/prism-toolbar.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/copy-to-clipboard/prism-copy-to-clipboard.min.js"></script>
  <!-- show-language plugin: displays the language label in the toolbar -->
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/show-language/prism-show-language.min.js"></script>
  <script src="{{ '/assets/js/code-enhance.js' | relative_url }}"></script>
</body>
</html>
